context.modules = [
  { name = libpipewire-module-filter-chain
    args = {
      node.description = "Soundbar_EQ"
      filter.graph = {
        nodes = [
          { type   = ladspa
            name   = eq_l
            plugin = {{.MbeqPath}}
            label  = mbeq
            control = {
{{- range .EQBands}}
              "{{.Label}}" = {{.Gain}}
{{- end}}
            }
          }
          { type   = ladspa
            name   = eq_r
            plugin = {{.MbeqPath}}
            label  = mbeq
            control = {
{{- range .EQBands}}
              "{{.Label}}" = {{.Gain}}
{{- end}}
            }
          }
        ]
        inputs  = [ "eq_l:Input" "eq_r:Input" ]
        outputs = [ "eq_r:Output" "eq_l:Output" ]
      }
      capture.props = {
        node.name        = bt_swap_sink
        media.class      = Audio/Sink
        audio.channels   = 2
        audio.position   = [ FL FR ]
        priority.session = 0
      }
      playback.props = {
        node.name         = bt_swap_sink_out
        audio.channels    = 2
        audio.position    = [ FL FR ]
        target.object     = "{{.PrimarySink}}"
        stream.dont-remix = true
        node.passive      = true
      }
    }
  }
]
